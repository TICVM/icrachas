rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Alunos: Permite listagem para logados, mas leitura individual (via token/id) para pais
    match /alunos/{document} {
      allow list: if request.auth != null;
      allow get: if true;
      allow write: if request.auth != null;
    }

    // Modelos de Crachá
    match /modelosCracha/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Estrutura Escolar
    match /segmentos/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /turmas/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Fichas de Avaliação: Permite leitura individual para pais (view mode)
    match /fichas_avaliacao/{document} {
      allow list: if request.auth != null;
      allow get: if true;
      allow write: if request.auth != null;
    }

    // Modelos de Ficha (Layouts Dinâmicos)
    match /fichas_layouts/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Links Compartilhados
    match /shared_reports/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Configurações Globais (Logo, etc)
    match /configuracoes/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
